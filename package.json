{
  "name": "minimiles",
  "version": "1.0.0",
  "description": "Custom Celo Composer project.",
  "private": true,
  "author": "minimiles",
  "license": "MIT",
  "scripts": {
    "react-app:dev": "yarn workspace @celo-composer-minipay-template/react-app dev",
    "react-app:build": "yarn workspace @celo-composer-minipay-template/react-app build",
    "react-app:start": "yarn workspace @celo-composer-minipay-template/react-app start",
    "react-app:lint": "yarn workspace @celo-composer-minipay-template/react-app lint",
    "website:dev": "pnpm --filter @akibamiles/website dev",
    "website:build": "pnpm --filter @akibamiles/website build",
    "website:start": "pnpm --filter @akibamiles/website start",
    "website:lint": "pnpm --filter @akibamiles/website lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/celo-org/celo-composer.git"
  },
  "bugs": {
    "url": "https://github.com/celo-org/celo-composer/issues"
  },
  "homepage": "https://github.com/celo-org/celo-composer/blob/main/README.md",
  "workspaces": [
    "packages/*",
    "hardhat/*"
  ],
  "keywords": [
    "celo-composer",
    "celo"
  ],
  "dependencies": {
    "posthog-js": "^1.302.2",
    "truncate-eth-address": "^1.0.2"
  }
}
