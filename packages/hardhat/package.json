{
  "name": "hardhat-project",
  "license": "MIT",
  "version": "1.0.0",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.7",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.11",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.11",
    "@nomicfoundation/ignition-core": "^0.15.5",
    "@openzeppelin/contracts": "^4.8.3",
    "@openzeppelin/contracts-upgradeable": "4.9.6",
    "@openzeppelin/hardhat-upgrades": "^3.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.7",
    "@witnet/solidity": "^3.1.1",
    "chai": "^4.2.0",
    "hardhat": "^2.28.0",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.1",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.3.0",
    "@chainlink/contracts-ccip": "^1.5.0",
    "@layerzerolabs/lz-evm-oapp-v2": "^3.0.168",
    "@layerzerolabs/lz-evm-protocol-v2": "^3.0.168",
    "@pythnetwork/entropy-sdk-solidity": "^2.2.1",
    "@safe-global/protocol-kit": "^6.0.4",
    "@supabase/supabase-js": "^2.0.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "solidity-bytes-utils": "^0.8.4",
    "witnet-solidity-bridge": "^2.0.18"
  },
  "scripts": {
    "compile": "hardhat compile",
    "tsc": "npx tsc -p . && cp typechain/*.d.ts dist/typechain/",
    "build": "yarn compile && yarn tsc",
    "clean": "hardhat clean",
    "run:node": "hardhat node",
    "test": "hardhat test",
    "claw:batch:dry": "hardhat run --no-compile scripts/open-claw-batch.ts --network celo",
    "claw:batch:open": "CLAW_BATCH_OPEN=1 hardhat run --no-compile scripts/open-claw-batch.ts --network celo",
    "claw:batch:upload": "hardhat run --no-compile scripts/upload-claw-manifest.ts --network celo",
    "claw:sessions": "hardhat run --no-compile scripts/find-claw-sessions.ts --network celo",
    "claw:settle": "hardhat run --no-compile scripts/settle-claw-session.ts --network celo",
    "claw:set-legendary-burns": "hardhat run --no-compile scripts/set-claw-legendary-burns-half-cap.ts --network celo",
    "prettier": "prettier --write 'contracts/**/*.sol' '**/*.ts'"
  }
}
