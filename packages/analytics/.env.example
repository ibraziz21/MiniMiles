# Supabase (server-side only — no NEXT_PUBLIC prefix)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Dashboard password — protect the analytics UI
ANALYTICS_SECRET=your-secret-password

# Dune API
DUNE_API_KEY=your-dune-api-key

# Public query IDs from https://dune.com/superchain_eco/akiba-miles
# Each query should return a single latest row with a numeric metric column.
DUNE_LIFETIME_USERS_QUERY_ID=5667458
DUNE_LIFETIME_USERS_COLUMN=lifetime_users

DUNE_WAU_QUERY_ID=
DUNE_WAU_COLUMN=
DUNE_WAU_TIMELINE_COLUMN=timeline

DUNE_RAFFLE_QUERY_ID=
DUNE_RAFFLE_COLUMN=

DUNE_TOTAL_MINTED_QUERY_ID=5668155
DUNE_TOTAL_MINTED_COLUMN=akiba_issued
