SUPABASE_URL=
SUPABASE_SERVICE_KEY=
RETRY_PK=
MINIPOINTS_ADDRESS=0xEeD878017f027FE96316007D0ca5fDA58Ee93a6b
MINIPOINTS_V2_ADDRESS=0xab93400000751fc17918940C202A66066885d628
ADMIN_QUEUE_SECRET=
PORT=3001

# ── Prosperity Pass worker ───────────────────────────────────────────────────
# Required relayer used to burn 100 Miles and deploy the Super Account safe.
PASS_RELAYER_KEY=

# Optional fallback name supported by the worker.
# BADGES_RELAYER_KEY=

# Superchain / Prosperity Pass config.
SUPERCHAIN_RPC_URL=https://forno.celo.org
SUPERCHAIN_MODULE_ADDRESS=0x58f5805b5072C3Dd157805132714E1dF40E79c66
SUPERCHAIN_GUARD_ADDRESS=0xED12D87487B372cf4447C8147a89aA01C133Dc52
SUPERCHAIN_SETUP_ADDRESS=0xe0651391D3fEF63F14FB33C9cf4F157F3eD0F4AF
ERC4337_MODULE_ADDRESS=0x75cf11467937ce3F2f357CE24ffc3DBF8fD5c226
SAFE_VERSION=1.4.1

# ── Dice sweeper ──────────────────────────────────────────────────────────────
# Relayer wallet that calls requestRoundRandomness / drawRound.
CELO_RELAYER_PK=

# Celo JSON-RPC endpoint (defaults to public forno).
CELO_RPC_URL=https://forno.celo.org

# AkibaDice proxy address (default is mainnet).
DICE_ADDRESS=0xf77e7395Aa5c89BcC8d6e23F67a9c7914AB9702a

# How often to sweep active rounds, in seconds (default 60).
DICE_SWEEP_INTERVAL_SECONDS=60

# Optional: override which tiers to scan (comma-separated, default all).
# DICE_TIERS=10,20,30,250,500,1000

# Buffer added on top of the Witnet fee estimate, in basis points (default 1000 = 10%).
# DICE_FEE_BUFFER_BPS=1000

# Hard fallback fee in wei if Witnet fee estimation fails entirely.
# WITNET_FEE_WEI=15000000000000000
